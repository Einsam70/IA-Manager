# Runtime data
/app/db/*.sqlite
/app/db/*.sqlite-*
/app/incoming/*
/app/tmp/*
/app/public/data/models/*
/app/public/data/photos/*
/app/public/data/_tmp/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Logs and local configuration
*.log
.env
.env.*

# Portable runtimes and local archives
/php/
/app/python/WPy64-*/
/XX_Trastero/
*.rar
*.zip

# Editors and operating systems
.idea/
.vscode/
.DS_Store
Thumbs.db

# Keep required empty directories
!/app/db/.gitkeep
!/app/incoming/.gitkeep
!/app/incoming/ai/
!/app/incoming/ai/.gitkeep
!/app/incoming/photos/
!/app/incoming/photos/.gitkeep
!/app/tmp/.gitkeep
!/app/tmp/uploads/
!/app/tmp/uploads/.gitkeep
!/app/public/data/models/.gitkeep
!/app/public/data/photos/.gitkeep
